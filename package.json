    "auto-launch": "^5.0.6",
    "cbor-x": "^1.6.4",
    "date-fns": "^4.4.0",
    "electron-updater": "^6.8.9",
    "es-toolkit": "^1.49.0",
    "fast-glob": "^3.3.3",
    "filesize": "^11.0.22",
    "fs-extra": "^11.3.6",
    "html-to-text": "^10.0.0",
    "ky": "^2.0.2",
    "ms": "^2.1.3",
    "p-limit": "^7.3.0",
    "p-queue": "^9.3.1",

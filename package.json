{
  "name": "kiosk-downloader",
  "version": "1.7.0",
  "private": true,
  "description": "Unofficial Kiosk Downloader",
  "main": "./out/main/index.js",
  "scripts": {
    "build": "electron-vite build",
    "build:mac": "electron-vite build && electron-builder --mac --publish never",
    "build:unpack": "pnpm run build && electron-builder --dir",
    "build:win": "pnpm run build && electron-builder --win --publish never",
    "clean": "rimraf dist",
    "dev": "electron-vite dev",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --type-aware --type-check",
    "lint:fix": "oxlint --fix",
    "postinstall": "install-electron && electron-builder install-app-deps",
    "release": "semantic-release",
    "start": "electron-vite preview",
    "test": "vitest run",
    "typecheck": "oxlint --type-aware --type-check"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",

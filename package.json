    "electron-vite": "^5.0.0",
    "lucide-react": "^1.25.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "semantic-release": "^25.0.8",
    "sonner": "^2.0.7",
